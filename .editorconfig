root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.{js,css,html,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

[static/vendor/**]
# Vendored third-party code — leave it exactly as upstream ships it.
insert_final_newline = unset
trim_trailing_whitespace = unset

[*.bat]
end_of_line = crlf
